<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cobazaar.system.mapper.RoleMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.cobazaar.system.entity.Role">
        <id column="id" property="id" />
        <result column="role_name" property="roleName" />
        <result column="role_key" property="roleCode" />
        <result column="role_sort" property="sort" />
        <result column="status" property="status" />
        <result column="remark" property="remark" />
    </resultMap>

    <!-- 分页查询角色列表 -->
    <select id="selectRolePage" resultMap="BaseResultMap">
        SELECT * FROM sys_role
        <where>
            <if test="params.roleName != null and params.roleName != ''">
                <!-- 使用bind函数避免SQL注入 -->
                <bind name="roleNameLike" value="'%' + params.roleName + '%'" />
                AND role_name LIKE #{roleNameLike}
            </if>
            <if test="params.status != null">
                AND status = #{params.status}
            </if>
        </where>
        <choose>
            <when test="params.sortField != null and params.sortField != ''">
                ORDER BY ${params.sortField} ${params.sortOrder}
            </when>
            <otherwise>
                ORDER BY id ASC
            </otherwise>
        </choose>
    </select>

</mapper>
